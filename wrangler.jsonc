{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "keel-site",
  "main": "src/worker.ts",
  "compatibility_date": "2024-11-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "routes": [
    { "pattern": "keeljs.com/*", "zone_name": "keeljs.com" },
    { "pattern": "www.keeljs.com", "custom_domain": true }
  ],
  "observability": {
    "enabled": true
  }
}
