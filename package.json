{
  "name": "keel-site",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "The website for the Keel framework — a Keel app running on Cloudflare Workers.",
  "scripts": {
    "docs": "node scripts/build-docs.mjs",
    "dev": "npm run docs && wrangler dev",
    "deploy": "npm run docs && wrangler deploy",
    "typecheck": "npm run docs && tsc --noEmit"
  },
  "dependencies": {
    "@shaferllc/keel": "^0.85.0",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@types/node": "^22.10.0",
    "marked": "^18.0.6",
    "typescript": "^5.7.2",
    "wrangler": "^4.0.0"
  }
}
